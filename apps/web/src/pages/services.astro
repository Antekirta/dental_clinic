---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { fetchServices } from "@/lib/services";

export const prerender = true;

const { directusBaseUrl, error, services } = await fetchServices();

const currencyFormatter = new Intl.NumberFormat("en-US", {
  style: "currency",
  currency: "USD",
  maximumFractionDigits: 2
});
---

<BaseLayout
  title="Dental Services"
  description="Static services page generated by Astro from Directus."
>
  <section class="space-y-8">
    <div class="space-y-3">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary">Services</p>
      <h1 class="text-4xl font-semibold tracking-tight text-foreground sm:text-5xl">
        Build-time rendered service catalog
      </h1>
      <p class="max-w-3xl text-base leading-7 text-muted-foreground sm:text-lg">
        Astro fetches this list from Directus while building the site. There is no server-side
        page runtime on the Astro side.
      </p>
      <p class="text-sm text-muted-foreground">
        Source CMS:
        <span class="font-medium text-foreground">{directusBaseUrl}/items/services</span>
      </p>
    </div>

    {
      error ? (
        <div class="rounded-3xl border border-destructive/30 bg-destructive/5 p-6 text-sm text-foreground">
          <p class="font-semibold">The services list could not be fetched during build.</p>
          <p class="mt-2 text-muted-foreground">
            Start Directus first, expose the `services` collection to the public role, or set
            <code>DIRECTUS_URL</code> before running the Astro build.
          </p>
          <p class="mt-3 break-all text-muted-foreground">Fetch error: {error}</p>
        </div>
      ) : null
    }

    {
      services.length > 0 ? (
        <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
          {services.map((service) => (
            <article class="rounded-[24px] border border-border/70 bg-card/85 p-6 shadow-[0_20px_60px_rgba(15,23,42,0.06)]">
              <div class="flex items-start justify-between gap-4">
                <div>
                  {service.category_name ? (
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-primary">
                      {service.category_name}
                    </p>
                  ) : null}
                  <h2 class:list={[
                    "text-xl font-semibold tracking-tight text-foreground",
                    service.category_name ? "mt-2" : ""
                  ]}>
                    {service.name}
                  </h2>
                </div>
                <div class="rounded-full bg-primary/10 px-3 py-1 text-sm font-semibold text-primary">
                  {currencyFormatter.format(Number(service.base_price))}
                </div>
              </div>

              <p class="mt-4 text-sm leading-6 text-muted-foreground">
                {service.description ?? "Description will be added for this service."}
              </p>

              <div class="mt-6 flex items-center justify-between border-t border-border/70 pt-4 text-sm text-muted-foreground">
                <span>Duration</span>
                <span class="font-medium text-foreground">
                  {service.duration_min > 0 ? `${service.duration_min} min` : "Not specified"}
                </span>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="rounded-[24px] border border-dashed border-border p-8 text-sm text-muted-foreground">
          No services were available for the build.
        </div>
      )
    }
  </section>
</BaseLayout>
