# FastAPI / local app data
# =========================
*.log
*.sqlite3
*.db

# Environment files
.env
.env.*
!.env.example
!.env.local.example
!.env.prod.example

# =========================
# Alembic
# =========================
# Usually keep migrations in git.
# Ignore only pycache inside migrations.
**/alembic/__pycache__/
**/alembic/versions/__pycache__/

# =========================
# Node / Astro
# =========================
node_modules/
.pnpm-store/
.npm/
.yarn/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz

# Build outputs
dist/
.cache/
.parcel-cache/
.next/
.nuxt/
.svelte-kit/
.turbo/

# Astro
.astro/

# Vite
vite.svg

# TypeScript
*.tsbuildinfo

# =========================
# Docker
# =========================
docker-data/
*.pid

# =========================
# n8n local runtime data
# =========================
apps/automations/.n8n/*
!apps/automations/.n8n/.gitkeep

# =========================
# Directus local runtime data
