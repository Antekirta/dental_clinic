.DS_Store
Thumbs.db

# =========================
# IDE
# =========================
.idea/
.vscode/
*.iml

# =========================
# Python
# =========================
__pycache__/
*.py[cod]
*$py.class

# Python packaging
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Test / coverage / tooling
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# Virtual environments
.venv/
venv/
env/

